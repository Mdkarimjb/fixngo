# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fixngo?schema=public

# JWT
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_REFRESH_TTL=30d

# Redis
REDIS_URL=redis://localhost:6379

# OTP behaviour
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# Dev bypass: when true, any OTP is accepted so you can log in without MSG91.
OTP_DEV_BYPASS=true

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MSG91 (OTP/SMS)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Firebase Cloud Messaging
FCM_SERVER_KEY=
